# Between the Bread — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.
#
# Vite only exposes variables prefixed with VITE_ to browser code.
# All other variables are build-time only.

# ─── Phase 1: Analytics ───────────────────────────────────────────────────────
# PostHog project key and host (https://posthog.com)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── Phase 2+: Supabase (server-side — Vercel Functions) ─────────────────────
# Used by /api/* serverless functions. Never exposed to the browser.
# Project URL and publishable key from Supabase dashboard → Settings → Data API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Phase 3+: Supabase (client-side — Auth SDK) ─────────────────────────────
# Used by the browser for Supabase Auth (login, signup, OAuth).
# Same values as above but VITE_ prefixed so Vite exposes them to the bundle.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
