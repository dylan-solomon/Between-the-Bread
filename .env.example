# Between the Bread — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.
#
# Vite only exposes variables prefixed with VITE_ to browser code.
# All other variables are build-time only.

# ─── Phase 1: Analytics ───────────────────────────────────────────────────────
# PostHog project key and host (https://posthog.com)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── Phase 2+: Supabase ───────────────────────────────────────────────────────
# Project URL and anon (public) key from Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
